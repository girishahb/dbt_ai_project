# Copy to terraform.tfvars (git-ignored) and fill in. See agent/README.md
# for where each of these values comes from.

aws_region             = "us-east-1"
mwaa_environment_name  = "dbt-ai-project-mwaa"

vpc_id              = "vpc-xxxxxxxx"          # same VPC as the MWAA environment
subnet_ids          = ["subnet-xxxxxxxx"]     # needs outbound internet (NAT or public+assign_public_ip)
security_group_ids  = ["sg-xxxxxxxx"]         # must allow outbound HTTPS

databricks_host          = "dbc-xxxxxxxx-xxxx.cloud.databricks.com"
databricks_http_path     = "/sql/1.0/warehouses/xxxxxxxxxxxxxxxx"
databricks_catalog       = "ai_project"
databricks_ci_schema     = "agent_ci"
databricks_ci_client_id  = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # agent_ci* service principal's Application id

github_app_id = "123456"

# Optional overrides (see infra/variables.tf for defaults):
# bedrock_model_id = "anthropic.claude-sonnet-4-5-20250929-v1:0"
# agent_image_tag  = "latest"
