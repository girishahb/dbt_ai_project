# Copy this file to .env and fill in your Databricks connection details.
# Then load it into your shell session before running dbt, e.g. (PowerShell):
#   Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }

# Databricks workspace hostname, without https:// (e.g. adb-1234567890123456.7.azuredatabricks.net)
DBT_DATABRICKS_HOST=

# HTTP path of your SQL warehouse or cluster (Compute > your warehouse/cluster > Connection details)
DBT_DATABRICKS_HTTP_PATH=

# Personal access token (User Settings > Developer > Access tokens), or use a service principal token
DBT_DATABRICKS_TOKEN=

# Optional: Unity Catalog name (defaults to hive_metastore if not set)
DBT_DATABRICKS_CATALOG=

# Optional: target schema for dev output (defaults to dbt_ai_project_dev)
DBT_DATABRICKS_SCHEMA=

# Used by the `ci` target (profiles/profiles.yml) -- the self-heal agent and
# the dbt_ci.yml PR workflow validate candidate fixes here instead of prod.
# Optional: scratch schema for the ci target (defaults to agent_ci)
DBT_DATABRICKS_CI_SCHEMA=
# OAuth M2M credentials for a dedicated service principal scoped only to
# agent_ci* schemas (see agent/README.md for the exact GRANT statements).
# Application id / client id of that service principal (not sensitive)
DBT_DATABRICKS_CI_CLIENT_ID=
# OAuth secret generated for that service principal -- keep this out of git
DBT_DATABRICKS_CI_CLIENT_SECRET=
